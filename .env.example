# Server Configuration
PORT=3000

# Security (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://<your-os-username>@localhost:5432/hb_task_server

# Redis Cache (optional — required for multi-instance deployments)
# Without this, reads go directly to Postgres (single-instance only)
# REDIS_URL=redis://localhost:6379

# Token Encryption Key (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key-change-this-in-production

# Microsoft Graph API
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# Use "common" to allow any Microsoft account (personal or work/school).
# Use your specific tenant ID to restrict to one organization only.
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3500/auth/microsoft/callback

# Google Tasks API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Default task provider (microsoft or google — apple requires ENABLE_APPLE_PROVIDER=true)
DEFAULT_PROVIDER=microsoft

# Set to true only when running locally on macOS with Apple Reminders
ENABLE_APPLE_PROVIDER=false
