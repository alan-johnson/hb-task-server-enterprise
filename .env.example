# Server Configuration
PORT=3500
WEB_URL=https://your-domain.com

# Security (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database
# Format for DO Managed MySQL: mysql://user:password@<db-host>:25060/hb_task_server
# Format for local dev:        mysql://user:password@localhost:3306/hb_task_server
DATABASE_URL=mysql://<user>:<password>@localhost:3306/hb_task_server

# Path to the DO Managed MySQL CA cert (download from DO panel > Databases > CA certificate).
# Required for production (DO Managed MySQL enforces TLS on port 25060).
# Leave unset for local dev.
# DB_SSL_CA_PATH=/home/deploy/ca-certificate.crt

# Redis Cache — standard for this deployment (shared read cache + rate-limit
# store). Without this, reads go directly to MySQL and rate limits are
# tracked per-process instead of shared — the app still runs correctly, but
# see docs/DEPLOY.md Section 2 for why this should be set up by default.
# The password must match `requirepass` in /etc/redis/redis.conf.
REDIS_URL=redis://:<redis-password>@localhost:6379

# Token Encryption Key (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key-change-this-in-production

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Monthly price ID (used for the Monthly plan and as the base for Free Trial)
STRIPE_PRICE_ID_MONTHLY=price_...

# Annual price ID (used for the Annual plan)
STRIPE_PRICE_ID_ANNUAL=price_...

# Free-trial length in days before the monthly subscription begins (default: 14)
STRIPE_TRIAL_DAYS=14

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used to send account-verification emails on registration.
# If SMTP_HOST is omitted the server runs without email and logs verify URLs to
# the console — useful for local development, not suitable for production.
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=465
# Set to true only when using port 465 (implicit TLS); leave false for STARTTLS
SMTP_SECURE=true
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
# Displayed as the "From" address in all outgoing mail
SMTP_FROM=handsbreadth LLC <noreply@your-domain.com>

# Where operational alerts (e.g. repeated Stripe webhook signature failures) are sent.
# Falls back to SMTP_USER if not set.
ADMIN_ALERT_EMAIL=you@your-domain.com

# Microsoft Graph API
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# Use "common" to allow any Microsoft account (personal or work/school).
# Use your specific tenant ID to restrict to one organization only.
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3500/auth/microsoft/callback

# Google Tasks API
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Default task provider (microsoft, google, or apple)
DEFAULT_PROVIDER=microsoft

# ── Apple Reminders Bridge ───────────────────────────────────────────────────
# No configuration needed on this side. The local hb-task-server connects
# outbound to wss://<this-server>/bridge using a per-user API key.
# To set up: POST /auth/bridge/key (authenticated) to generate the key,
# then paste it into the local server's .env as BRIDGE_API_KEY.
