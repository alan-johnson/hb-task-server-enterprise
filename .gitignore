# Dependencies
node_modules/

# Environment variables (contains secrets — never commit)
.env
client_secret*.json

# User data (contains hashed passwords and OAuth tokens — never commit)
data/

# Server PID
.server.pid

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
*.rdb

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build
dist/
build/
coverage/

# Docs (internal/working docs stay untracked — see docs/ at repo root).
# src/public/docs/ is the deliberate exception: publicly-servable developer
# docs, copied there on purpose from the private docs/ above. Un-ignore it
# explicitly rather than relying on this pattern being anchored, since
# `docs/` with no leading slash matches a directory named docs at any depth.
docs/
!src/public/docs/
!src/public/docs/**
