{
  "name": "hb-task-server",
  "version": "0.1.0",
  "description": "Handsbreadth Multi-User Unified Task Server — REST API for Microsoft Tasks and Google Tasks",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:api": "node src/task-server.js",
    "start:web": "node src/web-server.js",
    "dev:api": "nodemon src/task-server.js",
    "dev:web": "nodemon src/web-server.js",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\""
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@iarna/toml": "^2.2.5",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^126.0.1",
    "http-proxy-middleware": "^2.0.6",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.12.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
